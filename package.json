{
  "name": "zenit",
  "version": "2.0.0",
  "description": "ZENIT - Plataforma de Detecção e Prevenção de Fraudes PIX usando Firebase",
  "main": "api/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report tests/reports/playwright",
    "test:chromium": "playwright test --project=chromium",
    "start:backend": "cd backend && node server-firebase.js",
    "start:frontend": "cd frontend && python -m http.server 8080",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build": "cd backend && npm install"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "firebase-admin": "^12.7.0",
    "node-cron": "^3.0.3",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.1",
    "validator": "^13.15.20",
    "winston": "^3.18.3",
    "ws": "^8.14.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatheusGino71/A3-sistemas.git"
  },
  "keywords": [
    "zenit",
    "pix",
    "fraud-detection",
    "firebase",
    "firestore",
    "anti-fraud"
  ],
  "author": "ZENIT Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MatheusGino71/A3-sistemas/issues"
  },
  "homepage": "https://github.com/MatheusGino71/A3-sistemas#readme",
  "devDependencies": {
    "@playwright/test": "^1.56.1"
  }
}
