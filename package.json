{
  "name": "zenit",
  "version": "2.0.0",
  "description": "ZENIT - Plataforma de Detecção e Prevenção de Fraudes PIX usando Firebase",
  "main": "backend/server-firebase.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report tests/reports/playwright",
    "test:chromium": "playwright test --project=chromium",
    "start:backend": "cd backend && node server-firebase.js",
    "start:frontend": "cd frontend && python -m http.server 8080",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatheusGino71/A3-sistemas.git"
  },
  "keywords": [
    "zenit",
    "pix",
    "fraud-detection",
    "firebase",
    "firestore",
    "anti-fraud"
  ],
  "author": "ZENIT Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MatheusGino71/A3-sistemas/issues"
  },
  "homepage": "https://github.com/MatheusGino71/A3-sistemas#readme",
  "devDependencies": {
    "@playwright/test": "^1.56.1"
  }
}
